{
  "name": "mermaidxp",
  "private": true,
  "version": "1.0.0",
  "description": "Interactive Mermaid diagram editor with real-time live collaboration, performance optimization, and enterprise deployment",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/pre-build-validation.cjs && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "echo '🧪 Running basic validation...' && npm run lint && echo '✅ Basic validation passed!'",
    "validate": "node scripts/pre-build-validation.cjs",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write .",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "firebase": "^12.3.0",
    "jspdf": "^4.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.0",
    "@eslint/js": "^9.29.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
